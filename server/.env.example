# OpenAI API key (for embeddings)
OPENAI_API_KEY=sk-...

# Supabase credentials (Settings > API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...      # service_role key (required — bypasses RLS)

# Telegram bot token (optional - only for server-telegram.js)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Allowed Telegram user IDs (comma-separated, empty = allow all)
ITACHI_ALLOWED_USERS=

# Server port (default: 3000)
PORT=3000
